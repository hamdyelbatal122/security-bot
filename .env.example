# ========================================
# Security Bot Environment Configuration
# ========================================
# Recommended: run `npm run setup` to generate this file automatically.
# Never commit your real .env file.

# GitHub App credentials
APP_ID=
PRIVATE_KEY_PATH=./private-key.pem
WEBHOOK_SECRET=

# Optional OAuth values
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Local server
PORT=3000

# Optional webhook forwarding URL (Smee)
WEBHOOK_PROXY_URL=https://smee.io/new
