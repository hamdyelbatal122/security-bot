# ========================================
# security-bot Environment Configuration
# ========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!

# GitHub App Credentials
# Get these from https://github.com/settings/apps/YOUR_APP_NAME
APP_ID=                    # App ID number (e.g., 123456)
PRIVATE_KEY_PATH=./private-key.pem  # Path to your GitHub App private key

# Webhook Configuration
WEBHOOK_SECRET=            # Strong random string (min 32 chars)

# OAuth (if you need it for additional features)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Server Configuration
PORT=3000                  # Port to run the webhook server on

# Optional: Local Development Tunnel
# WEBHOOK_PROXY_URL=https://smee.io/your-unique-channel
# Generate at: https://smee.io/new (for local development with GitHub webhooks)
