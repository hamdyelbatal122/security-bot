# ========================================
# security-bot Environment Configuration
# ========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!

# GitHub App Credentials
# Get these from https://github.com/settings/apps/YOUR_APP_NAME
APP_ID=
PRIVATE_KEY_PATH=

# Webhook Configuration
WEBHOOK_SECRET=

# OAuth (if you need it for additional features)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Server Configuration
PORT=3000

# Optional: Local Development Tunnel
WEBHOOK_PROXY_URL=https://smee.io/Fj2wCHQ3uZfiQf59
